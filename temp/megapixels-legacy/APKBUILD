# Maintainer: Adam Thiede <me@adamthiede.com>
pkgname=megapixels-legacy
_pkgname=megapixels
pkgver=0.16.1
pkgrel=0
pkgdesc="GTK+3 camera app for mobile devices"
url="https://gitlab.com/megapixels-org/Megapixels"
arch="all"
license="GPL-3.0-only"
# Required by postprocess.sh
# depends="cmd:dcraw_emu cmd:convert cmd:exiftool"
depends="libraw-tools imagemagick exiftool"
makedepends="glib-dev gtk+3.0-dev tiff-dev meson cmake zbar-dev"
source="
	$_pkgname-$pkgver.tar.gz::https://gitlab.com/megapixels-org/Megapixels/-/archive/$pkgver/Megapixels-$pkgver.tar.gz
	gcc-15.patch
"
builddir="$srcdir/Megapixels-$pkgver"
options="!check" # There's no testsuite

build() {
	abuild-meson . output
	meson compile -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}


