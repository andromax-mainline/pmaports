b13078e2bbb6e70c40067788de47eb0398d99d73a5f711cce2abb64f3fdd74b4b62de273ad628af9fe94c45df2010bb0bad134bfdfbe2be54ceb62e97d10f7ca  config-postmarketos-exynos5.armv7
"
