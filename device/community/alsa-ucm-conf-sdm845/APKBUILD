pkgname=alsa-ucm-conf-sdm845
pkgver=2
pkgrel=0
pkgdesc="ALSA UCM configuration for Qualcomm SDM845 devices"
url="https://postmarketos.org"
arch="aarch64"
license="BSD-3-Clause"
provides="alsa-ucm-conf"
provider_priority=1
replaces="soc-qcom-sdm845-ucm"
_commit="76515b850c66ebf53695d56c029acf3723fc643b"
source="$pkgname-$_commit.tar.gz::https://gitlab.com/f-izzo/alsa-ucm-conf/-/archive/$_commit/alsa-ucm-conf-$_commit.tar.gz"
options="!check"
builddir="$srcdir/$pkgname-$_commit"

package() {
	# install audio config files
	mkdir -p "$pkgdir"/usr/share/alsa
	cp -r "$srcdir/alsa-ucm-conf-$_commit"/ucm2 \
		"$pkgdir"/usr/share/alsa/
}

