fca9c5b53660443df908c3bd3134789b0bdd258955a27a2a8877d6667eb782cd9c1affcdd7cbb449e12916acc5b5b0b1d371e613ab98fc9e3881546f30368bae  tcpm-fix.patch
ff72cffd3a68da864df1128b902e4295d7353e0f8179d82e1d6b36a10b4e4768e31c88fc9c249b591b3bd89032da7a1c10ba1802f363b4dcca8dae703deee795  config-pine64-pinephonepro.aarch64
"
