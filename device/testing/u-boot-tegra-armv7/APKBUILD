# Contributor: Robert Eckelmann <longnoserob@postmarketos.org>
# Maintainer: Robert Eckelmann <longnoserob@postmarketos.org>
# Co-Maintainer: Svyatoslav Ryhel <clamor95@gmail.com>
pkgname=u-boot-tegra-armv7
pkgver=2025.07
pkgrel=0
pkgdesc="u-boot for nvidia tegra"
url="www.u-boot.org"
arch="armv7"
license="GPL-2.0+"
depends=""
makedepends="
	bc
	bison
	dtc
	flex
	gnutls-dev
	openssl-dev
	py3-setuptools
	python3-dev
	swig
"
checkdepends=""
install=""
options="!check !strip pmb:cross-native"
commit="fd98452486e37d34c5480f1d162d91bbb30d0b44"
source="$pkgname-${pkgver/_/-}.tar.bz2::https://gitlab.com/clamor-s/u-boot/-/archive/$commit/u-boot-$commit.tar.bz2
	u-boot-tegra-armv7.post-upgrade
"
builddir="$srcdir/u-boot-$commit/"
board_configs="
	chagall:chagall
	grouper:grouper
	lg:p880,p895
	ouya:ouya
	picasso:picasso
	qc750:qc750
	star:star
	surface:surface
	tegratab:tegratab
	transformer_t20:sl101,tf101,tf101g
	transformer_t30:transformer_t30
	tf701t:tf701t
"

for board_config in $board_configs; do
	_allboards="$_allboards $pkgname-${board_config%%:*}"
done

subpackages="$pkgname-all:_all $_allboards"

build() {
	touch include/config.h
	LC_ALL=C date +'#define U_BOOT_DATE "%b %d %C%y"' > include/timestamp_autogenerated.h
	LC_ALL=C date +'#define U_BOOT_TIME "%T"' >> include/timestamp_autogenerated.h

	local board_config board
	for board_config in $board_configs; do
		local configs="${board_config#*:}"
		for board in ${configs//,/ }; do
			msg "Building u-boot for $board"

			export BUILD_DIR="$builddir"/build/$board
			mkdir -p "$BUILD_DIR"

			# p880,p895,sl101,tf101,tf101g use dedicated configs which need to be taken care off
			# surface-rt is a workaround, as otherwise surface-rt would be treated as a subpackage of surface..
			case "$board" in
				"p880"|"p895")
					make O=$BUILD_DIR x3_t30_defconfig $(boad).config;;

				"sl101"|"tf101"|"tf101g")
					make O="$BUILD_DIR" transformer_t20_defconfig ${board}.config;;
				"surface")
					make O="$BUILD_DIR" surface-rt_defconfig;;
				*)
					make O="$BUILD_DIR" ${board}_defconfig;;
			esac

			make O="$BUILD_DIR"
		done
	done
}

package() {
	case "$CARCH" in
		x86*) return;;
	esac
	cd "$builddir"/build
	mkdir -p "$pkgdir"/usr/share/$pkgname "$pkgdir"/usr/sbin
}

_all() {
	pkgdesc="u-boot for all tegra boards (meta package)"
	depends="$_allboards"

	mkdir -p "$subpkgdir"/
}

_split_boards() {
	cd "$builddir"/build
	pkgdesc="u-boot for $1"
	depends="u-boot-tegra-armv7"
	shift
	local board
	for board; do
		msg "Including board $board"
		mkdir -p "$subpkgdir"/usr/share/$pkgname/$board
		export BUILD_DIR="$builddir"/build/$board

		local board_images=""

		local ok=no
		for image in $board_images u-boot-dtb-tegra.bin -- ; do
			if [ "$image" = "--" ]; then
				[ "$ok" = yes ] && break
				continue
			fi
			if [ -e "$BUILD_DIR"/$image ]; then
				cp "$BUILD_DIR"/$image "$subpkgdir"/usr/share/$pkgname/$board
				ok=yes
			fi
		done
		[ "$ok" = yes ] || return
	done
}

for board_config in $board_configs; do
	_board="${board_config%%:*}"
	_configs="${board_config#*:}"
	eval "$_board() { _split_boards $_board ${_configs//,/ }; }"
done

sha512sums="
