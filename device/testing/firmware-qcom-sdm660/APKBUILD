# Maintainer: m0rf30 <morf3089@gmail.com>
pkgname=firmware-qcom-sdm660
pkgver=1
pkgrel=1
pkgdesc="Firmware files for Qualcomm SDM630/SDM636/SDM660 devices"
url="https://postmarketos.org"
arch="aarch64"
license="proprietary"
options="!strip !check !archcheck !spdx !tracedeps pmb:cross-native"

_asus_x00td_commit="6e89e98d8d347b779ce1bcfdb42665e853314e09"
_bbry_athena_commit="6bf215b0946a9a1055dfa222d901b967cb771bf0"
_nokia_sdm660_commit="815817196ac8115d445305ed52409b2457b4bcb2"
_xiaomi_jasmine_commit="785f4c95ad84bd1daa747bd71211fdd419c0af01"
_xiaomi_lavender_commit="36a0f45ed788aa7cb532e72687d6adbdcc627faa"
_xiaomi_platina_commit="d3c57407b34d03ff3597f67129c2bb0bdcac3005"
_xiaomi_tulip_commit="466518cfbaa8dfc70f3cd83adbc989537cbe48f8"
_xiaomi_whyred_commit="59e6cff428b177a448dc5952089a9aad0c362295"

source="
	firmware-asus-x00td-$_asus_x00td_commit.tar.gz::https://github.com/TheMuppets/proprietary_vendor_asus_X00TD/archive/$_asus_x00td_commit.tar.gz
	firmware-bbry-athena-$_bbry_athena_commit.tar.gz::https://github.com/BlackberryOpenSource/proprietary_vendor_blackberry_athena/archive/$_bbry_athena_commit.tar.gz
	firmware-nokia-sdm660-$_nokia_sdm660_commit.tar.gz::https://github.com/TheMuppets/proprietary_vendor_nokia/archive/$_nokia_sdm660_commit.tar.gz
	firmware-xiaomi-jasmine-$_xiaomi_jasmine_commit.tar.gz::https://github.com/TheMuppets/proprietary_vendor_xiaomi_wayne-common/archive/$_xiaomi_jasmine_commit.tar.gz
	firmware-xiaomi-lavender-$_xiaomi_lavender_commit.tar.gz::https://github.com/TheMuppets/proprietary_vendor_xiaomi_lavender/archive/$_xiaomi_lavender_commit.tar.gz
	firmware-xiaomi-platina-$_xiaomi_platina_commit.tar.gz::https://github.com/TheMuppets/proprietary_vendor_xiaomi_platina/archive/$_xiaomi_platina_commit.tar.gz
	firmware-xiaomi-tulip-$_xiaomi_tulip_commit.tar.gz::https://github.com/M0Rf30/postmarketos-vendor-xiaomi-tulip/archive/$_xiaomi_tulip_commit.tar.gz
	firmware-xiaomi-whyred-$_xiaomi_whyred_commit.tar.gz::https://github.com/TheMuppets/proprietary_vendor_xiaomi_whyred/archive/$_xiaomi_whyred_commit.tar.gz
"

_basefwdir="/lib/firmware"

package() {
	# Asus ZenFone Max Pro M1 (x00td) - SDM636
	asus_x00td_dir="$srcdir/proprietary_vendor_asus_X00TD-$_asus_x00td_commit/proprietary/vendor/firmware"
	install -Dm644 "$asus_x00td_dir/a512_zap.b02" -t "$pkgdir/$_basefwdir/qcom/sdm636/asus/x00td"
	install -Dm644 "$asus_x00td_dir/a512_zap.mdt" -t "$pkgdir/$_basefwdir/qcom/sdm636/asus/x00td"

	# BlackBerry KEY2 (athena) - SDM660
	bbry_athena_dir="$srcdir/proprietary_vendor_blackberry_athena-$_bbry_athena_commit/proprietary/vendor/firmware"
	install -Dm644 "$bbry_athena_dir/a512_zap.b02" -t "$pkgdir/$_basefwdir/qcom/sdm660/athena"
	install -Dm644 "$bbry_athena_dir/a512_zap.mdt" -t "$pkgdir/$_basefwdir/qcom/sdm660/athena"

	# BlackBerry KEY2 LE (luna) - SDM636 - uses athena firmware (same Adreno 512)
	install -Dm644 "$bbry_athena_dir/a512_zap.b02" -t "$pkgdir/$_basefwdir/qcom/sdm636/luna"
	install -Dm644 "$bbry_athena_dir/a512_zap.mdt" -t "$pkgdir/$_basefwdir/qcom/sdm636/luna"

	# Nokia 6.1 (pl2) - SDM630
	nokia_sdm660_dir="$srcdir/proprietary_vendor_nokia-$_nokia_sdm660_commit/sdm660-common/proprietary/vendor/firmware"
	install -Dm644 "$nokia_sdm660_dir/a508_zap.b02" -t "$pkgdir/$_basefwdir/qcom/sdm630/nokia/pl2"
	install -Dm644 "$nokia_sdm660_dir/a508_zap.mdt" -t "$pkgdir/$_basefwdir/qcom/sdm630/nokia/pl2"

	# Xiaomi Mi Pad 4 (clover) - SDM660 - shares firmware with tulip
	xiaomi_tulip_dir="$srcdir/postmarketos-vendor-xiaomi-tulip-$_xiaomi_tulip_commit/qcom"
	install -Dm644 "$xiaomi_tulip_dir/a512_zap.b02" -t "$pkgdir/$_basefwdir/qcom/sdm660/xiaomi/clover"
	install -Dm644 "$xiaomi_tulip_dir/a512_zap.mdt" -t "$pkgdir/$_basefwdir/qcom/sdm660/xiaomi/clover"

	# Xiaomi Mi A2 (jasmine) - SDM660
	xiaomi_jasmine_dir="$srcdir/proprietary_vendor_xiaomi_wayne-common-$_xiaomi_jasmine_commit/proprietary/vendor/firmware"
	install -Dm644 "$xiaomi_jasmine_dir/a512_zap.b02" -t "$pkgdir/$_basefwdir/qcom/sdm660/xiaomi/jasmine"
	install -Dm644 "$xiaomi_jasmine_dir/a512_zap.mdt" -t "$pkgdir/$_basefwdir/qcom/sdm660/xiaomi/jasmine"

	# Xiaomi Redmi Note 7 (lavender) - SDM660
	xiaomi_lavender_dir="$srcdir/proprietary_vendor_xiaomi_lavender-$_xiaomi_lavender_commit/proprietary/vendor/firmware"
	install -Dm644 "$xiaomi_lavender_dir/a512_zap.b02" -t "$pkgdir/$_basefwdir/qcom/sdm660/xiaomi/lavender"
	install -Dm644 "$xiaomi_lavender_dir/a512_zap.mdt" -t "$pkgdir/$_basefwdir/qcom/sdm660/xiaomi/lavender"

	# Xiaomi Mi 8 Lite (platina) - SDM660
	xiaomi_platina_dir="$srcdir/proprietary_vendor_xiaomi_platina-$_xiaomi_platina_commit/proprietary/vendor/firmware"
	install -Dm644 "$xiaomi_platina_dir/a512_zap.b02" -t "$pkgdir/$_basefwdir/qcom/sdm660/xiaomi/platina"
	install -Dm644 "$xiaomi_platina_dir/a512_zap.mdt" -t "$pkgdir/$_basefwdir/qcom/sdm660/xiaomi/platina"

	# Xiaomi Redmi Note 6 Pro (tulip) - SDM636
	install -Dm644 "$xiaomi_tulip_dir/a512_zap.b02" -t "$pkgdir/$_basefwdir/qcom/sdm636/xiaomi/tulip"
	install -Dm644 "$xiaomi_tulip_dir/a512_zap.mdt" -t "$pkgdir/$_basefwdir/qcom/sdm636/xiaomi/tulip"

	# Xiaomi Redmi Note 5 Pro (whyred) - SDM636
	xiaomi_whyred_dir="$srcdir/proprietary_vendor_xiaomi_whyred-$_xiaomi_whyred_commit/proprietary/vendor/firmware"
	install -Dm644 "$xiaomi_whyred_dir/a512_zap.b02" -t "$pkgdir/$_basefwdir/qcom/sdm636/xiaomi/whyred"
	install -Dm644 "$xiaomi_whyred_dir/a512_zap.mdt" -t "$pkgdir/$_basefwdir/qcom/sdm636/xiaomi/whyred"
}

