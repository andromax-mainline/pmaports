5548043b7755e7518b1536e6de267276877fc95f99ab238c2972c05a04c4212e70e11fe3f7dccd09567ceacb7169a8678d3f8f46a0bf16663ac89894e95969f9  config-postmarketos-mediatek-mt6768.aarch64
"
